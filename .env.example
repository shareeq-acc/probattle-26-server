# Server Configuration
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000
INSTANCE_ID=1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neighbourly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Redis Configuration
# Option 1: Use URL (for local or simple connections)
REDIS_URL=redis://localhost:6379

# Option 2: Use individual parameters (for Redis Cloud, AWS ElastiCache, etc.)
# Uncomment and configure these for Redis Cloud:
# REDIS_HOST=redis-12917.crce206.ap-south-1-1.ec2.cloud.redislabs.com
# REDIS_PORT=12917
# REDIS_USERNAME=default
# REDIS_PASSWORD=your-password-here
# REDIS_TLS=true

# Examples:
# Redis with password (URL format): redis://:password@localhost:6379
# Redis Cloud with TLS (URL format): rediss://default:password@your-host:6379
# Redis with database selection: redis://localhost:6379/0

# RabbitMQ Configuration (DEPRECATED - Using Redis Pub/Sub instead)
# RABBITMQ_URL=amqp://localhost:5672
# RABBITMQ_USER=admin
# RABBITMQ_PASS=admin

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Firebase Cloud Messaging (Push Notifications)
# Get this from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Paste the entire JSON content on a single line
# Example: FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project",...}'
FIREBASE_SERVICE_ACCOUNT=

# Vercel (for production deployment)
VERCEL=false
